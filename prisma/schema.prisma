// Prisma スキーマ（データベースの設計図）
// 詳しい仕様は SPEC.md 参照。Phase 0 では解析1件を表す Analysis のみを扱う。

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// 解析1件（1動画1件）
model Analysis {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  gym          String? // ジム名（選択時のスナップショット）
  grade        String? // グレード（選択時のスナップショット）
  summary      String // 敗因
  prescription String // 処方
  thumbnail    String? // 先頭コマのサムネ（data URL）
  scores       Json? // 技術8軸のスコア（[{skill,score,evidence}]）
  holdColor    String? // 課題の色（入力時のスナップショット）
  wallAngle    String? // 壁の傾斜（入力時のスナップショット）
  note         String? // 登り手本人のメモ（落ちた場所・感触）
}

// マスタ：ジム
model Gym {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  grades    Grade[]
}

// マスタ：グレード（ジムごと。ジムによって基準が違うため Gym に紐づく）
model Grade {
  id         String   @id @default(cuid())
  gymId      String
  gym        Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  label      String
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
}
